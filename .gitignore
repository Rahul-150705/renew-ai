2.1 Main Class
@SpringBootApplication
public class TeachingAssistantApplication {
    public static void main(String[] args) {
        SpringApplication.run(TeachingAssistantApplication.class, args);
    }
}

2.2 Controller
@RestController
@RequestMapping("/api/lecture")
@CrossOrigin
public class LectureController {

    private final LectureService lectureService;

    public LectureController(LectureService lectureService) {
        this.lectureService = lectureService;
    }

    @PostMapping("/summarize")
    public SummaryResponse summarizeLecture(
            @RequestParam("file") MultipartFile file) {

        return lectureService.processLecture(file);
    }
}

2.3 Service Layer (Core Logic)
LectureService
@Service
public class LectureService {

    private final PdfExtractionService pdfService;
    private final SummarizationService summarizationService;

    public LectureService(PdfExtractionService pdfService,
                          SummarizationService summarizationService) {
        this.pdfService = pdfService;
        this.summarizationService = summarizationService;
    }

    public SummaryResponse processLecture(MultipartFile file) {
        String extractedText = pdfService.extractText(file);
        return summarizationService.generateSummary(extractedText);
    }
}

PDF Extraction
@Service
public class PdfExtractionService {

    public String extractText(MultipartFile file) {
        try (PDDocument document = PDDocument.load(file.getInputStream())) {
            PDFTextStripper stripper = new PDFTextStripper();
            return stripper.getText(document);
        } catch (IOException e) {
            throw new RuntimeException("Failed to extract PDF text");
        }
    }
}

AI Summarization
@Service
public class SummarizationService {

    private final LlmClient llmClient;

    public SummarizationService(LlmClient llmClient) {
        this.llmClient = llmClient;
    }

    public SummaryResponse generateSummary(String text) {
        String prompt = """
        Summarize the following lecture:
        - Key concepts
        - Important definitions
        - Exam-focused bullet points

        Lecture Content:
        """ + text;

        return llmClient.summarize(prompt);
    }
}

2.4 LLM Client (Pluggable)
@Component
public class LlmClient {

    public SummaryResponse summarize(String prompt) {
        // Call OpenAI / Claude / Gemini here
        // Keep it abstract for interviews

        return new SummaryResponse(
                "Lecture Summary",
                List.of("Point 1", "Point 2", "Point 3")
        );
    }
}

