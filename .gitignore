UploadLecture.jsx
export default function UploadLecture({ onResult }) {

  const upload = async (file) => {
    const formData = new FormData();
    formData.append("file", file);

    const res = await fetch("http://localhost:8080/api/lecture/summarize", {
      method: "POST",
      body: formData
    });

    onResult(await res.json());
  };

  return (
    <input type="file" onChange={e => upload(e.target.files[0])} />
  );
}

SummaryView.jsx
export default function SummaryView({ summary }) {
  return (
    <div>
      <h2>{summary.title}</h2>
      <ul>
        {summary.keyPoints.map((p, i) => <li key={i}>{p}</li>)}
      </ul>
    </div>
  );
}

App.jsx
import { useState } from "react";
import UploadLecture from "./components/UploadLecture";
import SummaryView from "./components/SummaryView";

function App() {
  const [summary, setSummary] = useState(null);

  return (
    <>
      <UploadLecture onResult={setSummary} />
      {summary && <SummaryView summary={summary} />}
    </>
  );
}

export default App;

